{
  "cells" : [
    {
      "cell_type" : "code",
      "execution_count" : 1,
      "metadata" : {},
      "outputs" : [],
      "source" : [
        "import pandas as pd\n", "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n", "\n", "\n",
        "sns.set_context('paper', font_scale=2., rc={\"lines.linewidth\": "
        "1.75} )\n",
        "sns.set_style({'font.weight': 'bold'})\n", "\n", "# Markers\n",
        "plt.rcParams['lines.markersize'] = 6.5\n",
        "plt.rcParams['lines.linewidth'] = 1.75\n",
        "plt.rcParams['figure.figsize'] = (8.7,6.27)"
      ]
    },
    {
      "cell_type" : "code",
      "execution_count" : null,
      "metadata" : {},
      "outputs" : [],
      "source" : [
        "copy_dataframe = pd.read_csv(f\"../bench_results_copy_fp16.csv\")\n",
        "# Input -> FP16 \n", "# Output -> FP16\n",
        "copy_dataframe['mem_bytes'] = (copy_dataframe['size'] * 2)  + "
        "copy_dataframe['size'] * 2\n",
        "copy_dataframe['bandwidth_gbps'] = (copy_dataframe['mem_bytes']) / "
        "(copy_dataframe['time_us'] * 1000) # GB/s"
      ]
    },
    {
      "cell_type" : "markdown",
      "metadata" : {},
      "source" : ["## MCSCAN bandwidth compute"]
    },
    {
      "cell_type" : "code",
      "execution_count" : 4,
      "metadata" : {},
      "outputs" : [],
      "source" : [
        "S = 128\n", "density = \"0.05\"\n", "dtype = \"fp16\"\n", "\n", "\n",
        "mcscan_dataframe = "
        "pd.read_csv(f\"../bench_results_mcscan_{S}_{dtype}.csv\")\n",
        "# Input -> FP16 \n", "# Output -> FP32\n",
        "mcscan_dataframe['mem_bytes'] = (mcscan_dataframe['size'] * 2)  + "
        "mcscan_dataframe['size'] * 4\n",
        "mcscan_dataframe['bandwidth_gbps'] = (mcscan_dataframe['mem_bytes']) "
        "/ (mcscan_dataframe['time_us'] * 1000) # GB/s"
      ]
    },
    {
      "cell_type" : "markdown",
      "metadata" : {},
      "source" : ["## Compress bandwidth compute"]
    },
    {
      "cell_type" : "code",
      "execution_count" : 5,
      "metadata" : {},
      "outputs" : [],
      "source" : [
        "compress_dataframe = "
        "pd.read_csv(f\"../bench_results_compress_{S}_{density}_fp32.csv\")\n",
        "\n", "# Input -> FP32 + INT8 -> 4 + 1\n", "# Output -> FP32 -> 4\n",
        "compress_dataframe['mem_bytes'] = (compress_dataframe['size'] * "
        "(4+1))  + compress_dataframe['outputsize'] * 4\n",
        "compress_dataframe['bandwidth_gbps'] = "
        "(compress_dataframe['mem_bytes']) / (compress_dataframe['time_us'] * "
        "1000) #GB/s"
      ]
    },
    {
      "cell_type" : "markdown",
      "metadata" : {},
      "source" : ["## DIFF Bandwidth Compute"]
    },
    {
      "cell_type" : "code",
      "execution_count" : 6,
      "metadata" : {},
      "outputs" : [],
      "source" : [
        "diff_dtype = \"fp32\"\n",
        "diff_dataframe = "
        "pd.read_csv(f\"../bench_results_diff_cann_{diff_dtype}.csv\")\n",
        "\n", "# Input -> FP32  \n", "# Output -> FP32 \n",
        "diff_dataframe['mem_bytes'] = (diff_dataframe['size'] * 4)  + "
        "diff_dataframe['size'] * 4\n",
        "diff_dataframe['bandwidth_gbps'] = (diff_dataframe['mem_bytes']) / "
        "(diff_dataframe['time_us'] * 1000) #GB/s"
      ]
    },
    {
      "cell_type" : "markdown",
      "metadata" : {},
      "source" : ["## Segmented Sum Bandwidth Compute"]
    },
    {
      "cell_type" : "code",
      "execution_count" : 7,
      "metadata" : {},
      "outputs" : [],
      "source" : [
        "# segsum_dataframe = "
        "pd.read_csv(f\"../"
        "bench_results_segmented_sum_{S}_{density}_{diff_dtype}.csv\")\n",
        "\n", "# Input -> FP16  \n", "# Output -> FP32 \n",
        "#segsum_dataframe['mem_bytes'] = (segsum_dataframe['size'] * (2))  + "
        "segsum_dataframe['outputsize'] * 4\n",
        "# segsum_dataframe['bandwidth_gbps'] = "
        "(segsum_dataframe['mem_bytes']) / (segsum_dataframe['time_us'] * "
        "1000) #GB/s\n"
      ]
    },
    {"cell_type" : "markdown", "metadata" : {}, "source" : ["## SCD Plot"]}, {
      "cell_type" : "code",
      "execution_count" : 27,
      "metadata" : {},
      "outputs" : [],
      "source" : [
        "tot_dataframe = pd.DataFrame()\n",
        "#tot_dataframe = pd.concat([tot_dataframe,copy_dataframe])\n",
        "tot_dataframe = pd.concat([tot_dataframe,mcscan_dataframe])\n",
        "tot_dataframe = pd.concat([tot_dataframe,compress_dataframe])\n",
        "tot_dataframe = pd.concat([tot_dataframe,diff_dataframe])\n",
        "#tot_dataframe = pd.concat([tot_dataframe,segsum_dataframe])\n", "\n",
        "tot_dataframe[\"time_ms\"] = tot_dataframe[\"time_us\"].astype(float) "
        "/ 1000.0\n"
      ]
    },
    {
      "cell_type" : "code",
      "execution_count" : null,
      "metadata" : {},
      "outputs" : [],
      "source" : [
        "plt.figure(figsize=(10, 5))\n",
        "# sns.lineplot(x='size', y='bandwidth_gbps', hue='operator', "
        "data=tot_dataframe, marker='o')\n",
        "\n",
        "pivot_df = tot_dataframe.pivot(index='size', columns='operator', "
        "values='time_ms')\n",
        "ax = pivot_df.plot(kind='bar', stacked=True)\n", "\n",
        "plt.xlabel('Number of elements')\n", "plt.ylabel('Time [ms]')\n",
        "plt.title('Segmented Sum Execution time break-down (density=0.05)')\n",
        "plt.legend(loc=\"upper left\")\n", "plt.tight_layout()\n", "\n",
        "#plt.grid(True)\n", "#filename = \"./scd.pdf\"\n",
        "#plt.savefig(filename)\n", "#plt.show()\n"
      ]
    },
